{
  "name": "scenario-loom",
  "version": "0.1.0",
  "private": true,
  "description": "A domain-agnostic Monte Carlo sandbox: drag sliders for mean, variance, and correlation and watch a live fan chart of thousands of simulated paths.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ctkrug/scenario-loom.git"
  },
  "homepage": "https://github.com/ctkrug/scenario-loom#readme",
  "bugs": {
    "url": "https://github.com/ctkrug/scenario-loom/issues"
  },
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": "^20.0.0 || >=22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/d3-array": "^3.2.1",
    "@types/d3-random": "^3.0.3",
    "@types/d3-scale": "^4.0.8",
    "@types/d3-selection": "^3.0.10",
    "@types/d3-shape": "^3.1.6",
    "@types/node": "^20.19.43",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^3.2.7",
    "eslint": "^8.57.0",
    "fast-check": "^4.9.0",
    "happy-dom": "^20.10.6",
    "prettier": "^3.9.5",
    "typescript": "^5.5.4",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "d3-array": "^3.2.4",
    "d3-random": "^3.0.1",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0"
  }
}
